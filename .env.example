# ============================================================
# Keeper Teams App - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# 
# CONFIGURATION METHODS:
#   1. KSM (Recommended for Production) - Secrets stored in Keeper Vault
#   2. Environment Variables (For Local Development) - Secrets in this file
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker-compose up -d
# ============================================================

# ==================== KSM Configuration (Recommended) ====================
# When KSM is configured, credentials are fetched securely from Keeper Vault
# This is more secure than storing credentials in environment variables
#
# To use KSM:
# 1. Create a KSM Application in Keeper Admin Console
# 2. Create two records in your vault:
#    - "CSMD config" with fields: service_url, api_key
#    - "CSMD teams config" with fields: client_id, client_secret, tenant_id, 
#      approvals_channel_id, approvals_team_id, pedm_enabled, device_approval_enabled
# 3. Share those records with the KSM Application
# 4. Get the KSM config token and base64 encode it

# KSM Configuration - Base64 encoded KSM config JSON
# Get this from Keeper Admin Console > Applications > Your KSM App
# KSM_CONFIG=eyJjbGllbnRJZCI6Ii4uLiIsImNsaWVudEtleSI6Ii4uLiJ9

# KSM Record Titles (or UIDs) - the records containing your credentials
COMMANDER_RECORD=CSMD config
TEAMS_RECORD=CSMD teams config

# ==================== Keeper Commander Configuration ====================
# These values configure the Keeper Commander Service Mode container

# Keeper user UID (from Keeper vault) - required for Commander container
KEEPER_USER_UID=your-keeper-user-uid

# KSM config for Commander container (can be same as KSM_CONFIG above)
# This is used by the Commander container to authenticate
KSM_CONFIG=your-ksm-config-base64

# Keeper record UID containing Commander configuration
KEEPER_RECORD=your-keeper-record-uid

# ==================== Fallback: Azure Bot Configuration ====================
# Only needed if NOT using KSM
# These values come from your Azure Bot registration
# Azure Portal > Bot Services > Your Bot > Configuration

# Application (client) ID from Azure AD app registration
CLIENT_ID=your-bot-client-id

# Client secret from Azure AD app registration
CLIENT_SECRET=your-bot-client-secret

# Directory (tenant) ID - use your tenant ID or "common" for multi-tenant
TENANT_ID=your-tenant-id

# Bot type: SingleTenant or MultiTenant
BOT_TYPE=MultiTenant

# ==================== Fallback: Keeper Service Mode Connection ====================
# Only needed if NOT using KSM
# The app connects to Commander Service Mode for vault operations

# URL of Keeper Commander Service Mode server
# For Docker: use http://commander:8900/api/v2/
# For local dev: use http://localhost:8900/api/v2/
KEEPER_SERVICE_URL=http://commander:8900/api/v2/

# API key for Keeper Service Mode (if using API key auth)
KEEPER_API_KEY=your-api-key

# ==================== Fallback: Teams Channel Configuration ====================
# Only needed if NOT using KSM
# Configure where approval requests are posted

# Channel ID where approval requests will be posted
# To get this: Right-click channel in Teams > "Get link to channel"
# Or send "/channel-status" to the bot in the channel
# Format: 19:xxx@thread.tacv2
APPROVALS_CHANNEL_ID=19:your-channel-id@thread.tacv2

# Team ID containing the approvals channel
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPROVALS_TEAM_ID=your-team-id

# ==================== Optional Features ====================

# Enable EPM (Endpoint Privilege Manager) polling
EPM_ENABLED=false

# Enable Cloud SSO Device Approval polling
DEVICE_APPROVAL_ENABLED=false

# Polling intervals in seconds (default: 120 = 2 minutes)
EPM_POLL_INTERVAL=120
DEVICE_POLL_INTERVAL=120

# ==================== Port Configuration ====================
# Optional: Override default ports

# Commander Service Mode port (default: 8900)
COMMANDER_PORT=8900

# Teams App port (default: 3978)
BOT_PORT=3978

# Health check port (default: 3979)
HEALTH_PORT=3979
